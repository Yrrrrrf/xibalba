{
  "workspace": [
    "./sdk/core",
    "./sdk/state",
    "./sdk/ui",
    "./apps/explorer",
    "./apps/vision"
  ],
  "tasks": {
    "prepare": "deno task --cwd sdk/ui prepack",
    "explorer": "deno task --cwd apps/explorer dev",
    "vision": "deno task --cwd apps/vision dev"
  },
  "compilerOptions": {
    "checkJs": false,
    "paths": {
      "@sdk/core": [
        "./sdk/core/src/mod.ts"
      ],
      "@sdk/state": [
        "./sdk/state/src/mod.ts"
      ],
      "@sdk/ui": [
        "./sdk/ui/src/mod.ts"
      ]
    }
  },
  "nodeModulesDir": "manual",
  "imports": {
    "@chenglou/pretext": "npm:@chenglou/pretext",
    "leaflet": "npm:leaflet",
    "surrealdb": "npm:surrealdb",
    "tailwindcss": "npm:tailwindcss",
    "vite": "npm:vite",
    "typescript": "npm:typescript@^5.9.3",
    "svelte": "npm:svelte",
    "@sveltejs/kit": "npm:@sveltejs/kit",
    "@sveltejs/adapter-static": "npm:@sveltejs/adapter-static",
    "@sveltejs/vite-plugin-svelte": "npm:@sveltejs/vite-plugin-svelte",
    "@tailwindcss/vite": "npm:@tailwindcss/vite",
    "@tailwindcss/forms": "npm:@tailwindcss/forms",
    "@tailwindcss/typography": "npm:@tailwindcss/typography",
    "daisyui": "npm:daisyui",
    "@inlang/paraglide-js": "npm:@inlang/paraglide-js",
    "sveltekit-superforms": "npm:sveltekit-superforms",
    "dinero.js": "npm:dinero.js",
    "rune-lab": "npm:rune-lab",
    "hotkeys-js": "npm:hotkeys-js"
  }
}
