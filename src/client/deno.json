{
  "workspace": [
    "./sdk/core",
    "./sdk/state",
    "./sdk/ui",
    "./apps/agent",
    "./apps/explorer",
    "./apps/vision"
  ],
  "tasks": {
    "prepare": "deno task --cwd sdk/ui prepack",
    "agent": "deno task --cwd apps/agent dev",
    "explorer": "deno task --cwd apps/explorer dev",
    "vision": "deno task --cwd apps/vision dev"
  },
  "compilerOptions": {
    "checkJs": false,
    "paths": {
      "@sdk/core": ["./sdk/core/src/mod.ts"],
      "@sdk/state": ["./sdk/state/src/mod.ts"],
      "@sdk/ui": ["./sdk/ui/src/mod.ts"]
    }
  },
  "nodeModulesDir": "manual",
  "imports": {
    "leaflet": "npm:leaflet@^1.9.4",
    "surrealdb": "npm:surrealdb@^2.0.2",
    "tailwindcss": "npm:tailwindcss@^4.1.18",
    "vite": "npm:vite@^7.3.1",
    "typescript": "npm:typescript@^5.9.3",
    "svelte": "npm:svelte@^5.50.2",
    "svelte-check": "npm:svelte-check@^4.3.6",
    "@sveltejs/kit": "npm:@sveltejs/kit@^2.50.2",
    "@sveltejs/adapter-static": "npm:@sveltejs/adapter-static@^3.0.10",
    "@sveltejs/vite-plugin-svelte": "npm:@sveltejs/vite-plugin-svelte@^6.2.4",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.18",
    "@tailwindcss/forms": "npm:@tailwindcss/forms@^0.5.11",
    "@tailwindcss/typography": "npm:@tailwindcss/typography@^0.5.19",
    "daisyui": "npm:daisyui@^5.5.18",
    "@inlang/paraglide-js": "npm:@inlang/paraglide-js@^2.11.0",
    "sveltekit-superforms": "npm:sveltekit-superforms@^2.29.1",
    "dinero.js": "npm:dinero.js@^2.0.0-alpha.16",
    "rune-lab": "npm:rune-lab@^0.1.2",
    "hotkeys-js": "npm:hotkeys-js@^4.0.0"
  },
  "lint": {
    "exclude": ["**/app.d.ts"]
  }
}
