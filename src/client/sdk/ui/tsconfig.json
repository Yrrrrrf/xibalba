{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ESNext",
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@sdk/core": [
        "../core/src/mod.ts"
      ],
      "@sdk/state": [
        "../state/src/mod.ts"
      ],
      "@sdk/ui": [
        "./src/mod.ts"
      ],
      "$lib": [
        "./src/lib"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.svelte",
    "src/**/*.d.ts"
  ]
}
